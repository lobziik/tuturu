{
  "name": "tuturu-app",
  "version": "1.0.0",
  "description": "WebRTC signaling server for tuturu video calling app",
  "type": "module",
  "scripts": {
    "build": "bun build src/client/index.tsx --minify --outdir public --target browser --sourcemap=inline",
    "build:watch": "bun build src/client/index.tsx --outdir public --target browser --sourcemap=inline --watch",
    "build:server": "bun build --compile --minify --sourcemap ./src/server/index.ts --outfile ./dist/server",
    "build:prod": "bun run build && bun run build:server",
    "dev": "bun run --hot src/server/index.ts",
    "start": "bun run src/server/index.ts",
    "start:prod": "./dist/server",
    "test": "bun test --randomize",
    "test:watch": "bun test --randomize --watch",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "lint": "bunx eslint . --ext .ts,.tsx --max-warnings=0",
    "lint:fix": "bunx eslint . --ext .ts,.tsx --fix",
    "format": "bunx prettier . --write",
    "format:check": "bunx prettier . --check",
    "check": "bun run lint && bun run format:check && bun run typecheck"
  },
  "dependencies": {
    "bun": "^1.3.11",
    "hash-wasm": "^4.12.0",
    "preact": "^10.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "bun-types": "latest",
    "eslint": "^9.39.4",
    "eslint-plugin-unused-imports": "^4.4.1",
    "fake-indexeddb": "^6.2.5",
    "globals": "^15.15.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
